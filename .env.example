# ==============================================================================
# DILGS - Dukgs Environment Variables
# ==============================================================================

# --- DATABASE (PostgreSQL / Supabase) ---
# Connection string for your PostgreSQL database (e.g., Supabase, Neon)
DATABASE_URL="postgres://postgres:[PASSWORD]@[HOST]:5432/postgres"

# --- STRIPE (Payments) ---
# Stripe Secret Key (sk_test_... or sk_live_...)
STRIPE_SECRET_KEY="sk_test_..."
# Stripe Public Key for Frontend (pk_test_... or pk_live_...)
VITE_STRIPE_PUBLIC_KEY="pk_test_..."
# Stripe Webhook Secret (whsec_...)
STRIPE_WEBHOOK_SECRET="whsec_..."

# --- SUPABASE (Direct API Access) ---
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key"

# --- AUTHENTICATION (Manus OAuth) ---
# Your Application ID from Manus
VITE_APP_ID="your-app-id"
# OAuth Server URL (Default: https://api.manus.im)
OAUTH_SERVER_URL="https://api.manus.im"
# OAuth Portal URL (Default: https://manus.im/login)
VITE_OAUTH_PORTAL_URL="https://manus.im/login"
# JWT Secret for session signing
JWT_SECRET="your-random-jwt-secret"

# --- BUSINESS CONFIGURATION ---
# The OpenID of the account that will have admin access
OWNER_OPEN_ID="your-owner-openid"
# The name of the owner/business
OWNER_NAME="DILGS"
# Admin Dashboard Access Token (Optional security layer)
ADMIN_DASHBOARD_TOKEN="your-admin-token"

# --- FRONTEND CONFIGURATION ---
# The final URL of your deployed application (used for Stripe redirects)
VITE_FRONTEND_URL="https://your-app.vercel.app"
SITE_URL="http://localhost:3000"

# --- EMAIL CONFIGURATION (Optional) ---
EMAIL_USER=""
EMAIL_PASS=""

# --- EXTERNAL SERVICES (Optional) ---
# Built-in Forge API (if applicable)
BUILT_IN_FORGE_API_URL=""
BUILT_IN_FORGE_API_KEY=""
VITE_FRONTEND_FORGE_API_URL=""
VITE_FRONTEND_FORGE_API_KEY=""
